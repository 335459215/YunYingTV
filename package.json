{
  "name": "yunying-tv",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "yarn": ">=1.22.0"
  },
  "main": "expo-router/entry",
  "scripts": {
    "start": "EXPO_USE_METRO_WORKSPACE_ROOT=1 expo start",
    "android": "EXPO_USE_METRO_WORKSPACE_ROOT=1 expo run:android",
    "ios": "EXPO_USE_METRO_WORKSPACE_ROOT=1 expo run:ios",
    "prebuild": "cross-env EXPO_USE_METRO_WORKSPACE_ROOT=1 expo prebuild --clean",
    "postprebuild": "node scripts/copy-config.js",
    "build": "yarn prebuild && cd android && ./gradlew assembleRelease",
    "build-debug": "cd android && ./gradlew assembleDebug",
    "test": "jest --watchAll",
    "test-ci": "jest --ci --coverage --no-cache",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "clean": "expo r -c && yarn cache clean && cd android && ./gradlew clean",
    "clean-modules": "rm -rf node_modules && yarn install",
    "reset-project": "node ./scripts/reset-project.js"
  },
  "jest": {
    "preset": "jest-expo"
  },
  "resolutions": {},
  "dependencies": {
    "@expo/metro-runtime": "~4.0.0",
    "@expo/vector-icons": "^14.0.0",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-cookies/cookies": "^6.2.1",
    "@react-navigation/native": "^6.1.18",
    "ajv": "^8.12.0",
    "cross-env": "^7.0.3",
    "debug": "^4.4.3",
    "expo": "~52.0.0",
    "expo-av": "~15.0.1",
    "expo-build-properties": "~0.13.1",
    "expo-cli": "^6.3.12",
    "expo-constants": "~17.0.2",
    "expo-font": "~13.0.1",
    "expo-intent-launcher": "~12.0.1",
    "expo-linear-gradient": "~14.0.1",
    "expo-linking": "~7.0.2",
    "expo-modules-autolinking": "~2.0.2",
    "expo-router": "~4.0.6",
    "expo-splash-screen": "~0.29.7",
    "expo-status-bar": "~2.0.0",
    "expo-system-ui": "~4.0.2",
    "expo-web-browser": "~14.0.0",
    "lucide-react-native": "^0.523.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.3",
    "react-native-blob-util": "^0.22.2",
    "react-native-file-viewer": "^2.1.5",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-keyboard-aware-scroll-view": "^0.9.5",
    "react-native-qrcode-svg": "^6.3.1",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "15.8.0",
    "react-native-tcp-socket": "^6.0.6",
    "react-native-toast-message": "^2.3.3",
    "react-native-web": "~0.19.13",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/jest": "^29.5.12",
    "@types/react": "~18.3.12",
    "@types/react-test-renderer": "^18.0.7",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~8.0.0",
    "expo-module-scripts": "^3.5.2",
    "jest": "^29.2.1",
    "jest-expo": "~52.0.0",
    "react-test-renderer": "18.3.1",
    "typescript": "~5.7.2"
  },
  "expo": {
    "install": {
      "exclude": [
        "react-native"
      ]
    }
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
